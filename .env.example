# 数据库连接（示例）
# DATABASE_URL="postgresql://user:password@localhost:5432/ai_space_station"

# NextAuth.js 配置（GitHub OAuth）
# 必需：从GitHub Developer Settings创建OAuth App获取
GITHUB_ID=your_github_oauth_client_id_here
GITHUB_SECRET=your_github_oauth_client_secret_here

# NextAuth.js 安全配置
# 生成密钥：openssl rand -base64 32 或使用 https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=http://localhost:3000  # 生产环境改为 https://your-domain.com

# API配置
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 支付集成（Stripe/Paddle）- 可选
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 邮件服务 - 可选
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@ai-space-station.com

# 其他服务 - 可选
NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXXXXXX-X